<!-- Purpose: Provide a functional WPF shell for enumerating windows, selecting current leader and follower windows, and resolving windows from typed process/title match rules. -->

<Window x:Class="InputBroadcaster.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="InputBroadcaster"
        Height="760"
        Width="1120"
        MinHeight="680"
        MinWidth="1020">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock FontSize="24"
                           FontWeight="Bold"
                           Text="InputBroadcaster" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="DimGray"
                           Text="Select live windows directly or resolve them from typed process/title match rules." />
            </StackPanel>

            <Button Grid.Column="1"
                    Padding="16,8"
                    Margin="16,0,0,0"
                    VerticalAlignment="Top"
                    Click="RefreshWindowsButton_OnClick"
                    Content="Refresh Windows" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Leader Window">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Foreground="DimGray"
                               Text="Use the current window list, or type a process/title rule and resolve a match." />

                    <ComboBox Grid.Row="2"
                              x:Name="LeaderComboBox"
                              MinWidth="320"
                              DisplayMemberPath="DisplayName" />

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Text="Process contains" />

                        <TextBox Grid.Column="2"
                                 x:Name="LeaderProcessFilterTextBox"
                                 MinWidth="220" />
                    </Grid>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Text="Title contains" />

                        <TextBox Grid.Column="2"
                                 x:Name="LeaderTitleFilterTextBox"
                                 MinWidth="220" />
                    </Grid>

                    <StackPanel Grid.Row="8"
                                Orientation="Horizontal">
                        <Button Width="130"
                                Click="SetLeaderButton_OnClick"
                                Content="Set Selected" />
                        <Button Width="130"
                                Margin="8,0,0,0"
                                Click="FindLeaderMatchButton_OnClick"
                                Content="Find Match" />
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Follower Window">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Foreground="DimGray"
                               Text="Use the current window list, or type a process/title rule and resolve a match." />

                    <ComboBox Grid.Row="2"
                              x:Name="FollowerComboBox"
                              MinWidth="320"
                              DisplayMemberPath="DisplayName" />

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Text="Process contains" />

                        <TextBox Grid.Column="2"
                                 x:Name="FollowerProcessFilterTextBox"
                                 MinWidth="220" />
                    </Grid>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center"
                                   Text="Title contains" />

                        <TextBox Grid.Column="2"
                                 x:Name="FollowerTitleFilterTextBox"
                                 MinWidth="220" />
                    </Grid>

                    <StackPanel Grid.Row="8"
                                Orientation="Horizontal">
                        <Button Width="130"
                                Click="SetFollowerButton_OnClick"
                                Content="Set Selected" />
                        <Button Width="130"
                                Margin="8,0,0,0"
                                Click="FindFollowerMatchButton_OnClick"
                                Content="Find Match" />
                    </StackPanel>
                </Grid>
            </GroupBox>
        </Grid>

        <GroupBox Grid.Row="4" Header="Broadcast State">
            <Grid Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusTextBlock"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Text="Idle" />

                <Button Grid.Column="2"
                        Width="110"
                        Click="StartBroadcastButton_OnClick"
                        Content="Start" />

                <Button Grid.Column="4"
                        Width="110"
                        Click="StopBroadcastButton_OnClick"
                        Content="Stop" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="6" Header="Session Log">
            <ListBox x:Name="LogListBox"
                     Margin="12"
                     FontFamily="Consolas"
                     HorizontalContentAlignment="Stretch" />
        </GroupBox>
    </Grid>
</Window>

